# =============================================================================
# Career Jarvis — environment configuration
# Copy to ".env" and fill in. All secrets live here, never in code.
# Validated at startup in src/config.py — missing required vars = clear error.
# =============================================================================

# --- App behavior ------------------------------------------------------------
# Poll interval for Gmail in minutes.
POLL_MINUTES=5
# Where to store SQLite state + the OAuth token. Relative to project root.
STATE_DB_PATH=.data/career_jarvis.db
TOKEN_PATH=.data/token.json
# Path to the OAuth client credentials you download from Google Cloud.
GMAIL_CREDENTIALS_JSON=.data/credentials.json
# Comma-separated sender addresses to hard-skip (e.g. your own address).
SKIP_SENDERS=

# --- LLM (REQUIREMENT A: model-agnostic via LiteLLM) -------------------------
# Per-role model selection. Any LiteLLM model string works.
# Anthropic default (sensible):
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
DRAFTER_MODEL=claude-sonnet-4-5-20250929
# Optional: OpenAI-compatible / local endpoint base URL.
#   - Ollama:  http://localhost:11434
#   - vLLM/LM Studio/text-generation-webui: their OpenAI-compatible URL
LLM_BASE_URL=
# Provider API key. Leave blank for purely local models (e.g. Ollama).
# For Anthropic use ANTHROPIC_API_KEY; OpenAI uses OPENAI_API_KEY; etc.
# LiteLLM reads provider keys from conventional env vars automatically.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
TOGETHERAI_API_KEY=
OPENROUTER_API_KEY=
LLM_API_KEY=
# Max tokens for the drafter (classifier uses a small fixed budget).
DRAFTER_MAX_TOKENS=600
# Per-request timeout for LLM calls, seconds.
LLM_TIMEOUT=60

# --- Notification channel (REQUIREMENT B: pluggable) -------------------------
# One of: ntfy (default/recommended), whatsapp, pushover, discord
NOTIFY_CHANNEL=ntfy

# ntfy.sh (default) — install the ntfy app, subscribe to a secret topic.
NTFY_TOPIC=
NTFY_BASE_URL=https://ntfy.sh
# Optional access token for protected topics.
NTFY_TOKEN=

# CallMeBot WhatsApp — one-time setup:
# 1) Add +34 600 83 81 81 (the CallMeBot WhatsApp bot) to your contacts.
# 2) Message it: "I allow callmebot to send me messages".
# 3) It replies with your API key. Put it below.
WHATSAPP_PHONE=
WHATSAPP_APIKEY=

# Pushover — buy the $5 app, create an app at pushover.net.
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Discord — create a webhook in a server channel's integration settings.
DISCORD_WEBHOOK_URL=

# --- Optional: direct LinkedIn ingestion -----------------------------------
# WARNING: against LinkedIn ToS; account-restriction risk. Default OFF.
# When enabled, you must also: pip install playwright && playwright install chromium
# and manually log into LinkedIn once in the persistent browser profile.
LINKEDIN_ENABLED=false
LINKEDIN_PROFILE_DIR=.data/linkedin_profile
LINKEDIN_POLL_HOURS=6
LINKEDIN_MAX_THREADS=20

# =============================================================================
# --- Fully-local, zero-API-cost mode (Ollama) ---------------------------------
# Uncomment this block (and comment out the Anthropic block above) to run
# 100% offline. Install Ollama (https://ollama.com) and pull the models:
#   ollama pull llama3.1:8b      # classifier (cheap)
#   ollama pull llama3.3         # drafter (stronger)
# Then set:
# CLASSIFIER_MODEL=ollama/llama3.1
# DRAFTER_MODEL=ollama/llama3.3
# LLM_BASE_URL=http://localhost:11434
# LLM_API_KEY=
# (LiteLLM accepts ollama/ model strings; base_url is optional since LiteLLM
#  knows Ollama's default, but set it explicitly if you run on another port.)
# =============================================================================
